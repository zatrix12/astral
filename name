-- =============================================================================
-- SERVICES & GLOBAL VARIABLES
-- =============================================================================
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local TeleportService = game:GetService("TeleportService")
local HttpService = game:GetService("HttpService")

local LocalPlayer = Players.LocalPlayer

local isRunning = shared.CorvoAutoStart or false
local autoHopEnabled = shared.CorvoHopStart or false
local isMenuOpen = true
local corvoGui = nil

shared.CorvoAutoStart = nil
shared.CorvoHopStart = nil

-- =============================================================================
-- UTILITY FUNCTIONS
-- =============================================================================

local function getHumanoidRootPart()
	local character = LocalPlayer.Character
	if not character then return nil end
	return character:FindFirstChild("HumanoidRootPart")
end

-- Claims only the prompt specifically attached to the crow we teleported to
local function claimTargetReward(targetObject)
	local hrp = getHumanoidRootPart()
	if not hrp then return end
	
	-- Look for a ProximityPrompt inside or near the specific spawn object
	local prompt = targetObject:FindFirstChildWhichIsA("ProximityPrompt", true)
	
	if prompt then
		prompt:InputHoldBegin()
		task.wait(prompt.HoldDuration + 0.05)
		prompt:InputHoldEnd()
	end
end

-- Scans the folder to see if any actual Crows/Prompts exist right now
local function getActiveCrows()
	local worlds = workspace:FindFirstChild("Worlds")
	local world6 = worlds and worlds:FindFirstChild("6")
	local spawnFolder = world6 and world6:FindFirstChild("CorvoSpawns")
	
	if not spawnFolder then return {} end
	
	local activeList = {}
	for _, child in ipairs(spawnFolder:GetChildren()) do
		-- Checks if the spawn location actually contains a ProximityPrompt (meaning a crow is there)
		if child:FindFirstChildWhichIsA("ProximityPrompt", true) then
			table.insert(activeList, child)
		end
	end
	return activeList
end

-- =============================================================================
-- SMART SERVER HOPPING LOGIC
-- =============================================================================
local function serverHop()
	local carryOverScript = [[
		shared.CorvoAutoStart = true
		shared.CorvoHopStart = true
		loadstring(game:HttpGet("https://raw.githubusercontent.com/zatrix12/astral/refs/heads/main/name"))()
	]]
	
	local queue = queue_on_teleport or (syn and syn.queue_on_teleport)
	if queue then
		queue(carryOverScript)
	end

	local success, err = pcall(function()
		local url = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"
		local req = game:HttpGet(url)
		local body = HttpService:JSONDecode(req)
		
		if body and body.data then
			for _, server in ipairs(body.data) do
				if server.playing < server.maxPlayers and server.playing > 1 and server.id ~= game.JobId then
					TeleportService:TeleportToPlaceInstance(game.PlaceId, server.id, LocalPlayer)
					return
				end
			end
		end
	end)
	
	if not success then
		TeleportService:Teleport(game.PlaceId, LocalPlayer)
	end
end

-- =============================================================================
-- DRAG PHYSICS
-- =============================================================================
local function enableGuiDragging(frame)
	local dragging = false
	local dragInput, dragStart, startPos

	frame.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			dragStart = input.Position
			startPos = frame.Position

			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)

	frame.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement then
			dragInput = input
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if input == dragInput and dragging then
			local delta = input.Position - dragStart
			frame.Position = UDim2.new(
				startPos.X.Scale, 
				startPos.X.Offset + delta.X, 
				startPos.Y.Scale, 
				startPos.Y.Offset + delta.Y
			)
		end
	end)
end

