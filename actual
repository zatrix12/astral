	CloseButton.Size = UDim2.new(0, 24, 0, 24)
	CloseButton.Position = UDim2.new(1, -32, 0, 8)
	CloseButton.BackgroundColor3 = Color3.fromRGB(28, 28, 28)
	CloseButton.Text = "×"
	CloseButton.TextColor3 = Color3.fromRGB(180, 180, 180)
	CloseButton.Font = Enum.Font.GothamMedium
	CloseButton.TextSize = 18
	CloseButton.Parent = Header

	local CloseCorner = Instance.new("UICorner")
	CloseCorner.CornerRadius = UDim.new(0, 6)
	CloseCorner.Parent = CloseButton

	-- Left Sidebar Layout Channel
	local Sidebar = Instance.new("Frame")
	Sidebar.Name = "Sidebar"
	Sidebar.Size = UDim2.new(0, 125, 1, -55)
	Sidebar.Position = UDim2.new(0, 12, 0, 45)
	Sidebar.BackgroundColor3 = Color3.fromRGB(24, 24, 24)
	Sidebar.BorderSizePixel = 0
	Sidebar.Parent = MainFrame

	local SidebarCorner = Instance.new("UICorner")
	SidebarCorner.CornerRadius = UDim.new(0, 8)
	SidebarCorner.Parent = Sidebar

	local SidebarList = Instance.new("UIListLayout")
	SidebarList.Padding = UDim.new(0, 5)
	SidebarList.HorizontalAlignment = Enum.HorizontalAlignment.Center
	SidebarList.SortOrder = Enum.SortOrder.LayoutOrder
	SidebarList.Parent = Sidebar

	local SidebarPadding = Instance.new("UIPadding")
	SidebarPadding.PaddingTop = UDim.new(0, 8)
	SidebarPadding.Parent = Sidebar

	-- Right Content View Window
	local ContainerFrame = Instance.new("Frame")
	ContainerFrame.Name = "ContainerFrame"
	ContainerFrame.Size = UDim2.new(1, -160, 1, -55)
	ContainerFrame.Position = UDim2.new(0, 148, 0, 45)
	ContainerFrame.BackgroundTransparency = 1
	ContainerFrame.Parent = MainFrame

	local pages = {}
	local tabButtons = {}

	-- Modular Tab Generator Function
	local function createPageAndTab(tabName, layoutOrder)
		local page = Instance.new("ScrollingFrame")
		page.Name = tabName .. "Page"
		page.Size = UDim2.new(1, 0, 1, 0)
		page.BackgroundTransparency = 1
		page.CanvasSize = UDim2.new(0, 0, 0, 0)
		page.ScrollBarThickness = 3
		page.ScrollBarImageColor3 = Color3.fromRGB(60, 60, 60)
		page.Visible = false
		page.Parent = ContainerFrame
		
		local pageList = Instance.new("UIListLayout")
		pageList.Padding = UDim.new(0, 8)
		pageList.HorizontalAlignment = Enum.HorizontalAlignment.Center
		pageList.SortOrder = Enum.SortOrder.LayoutOrder
		pageList.Parent = page
		
		pages[tabName] = page
		
		local btn = Instance.new("TextButton")
		btn.Name = tabName .. "Tab"
		btn.Size = UDim2.new(0, 110, 0, 34)
		btn.BackgroundColor3 = Color3.fromRGB(24, 24, 24)
		btn.BackgroundTransparency = 1
		btn.Text = "   " .. tabName
		btn.TextColor3 = Color3.fromRGB(140, 140, 140)
		btn.Font = Enum.Font.GothamMedium
		btn.TextSize = 13
		btn.TextXAlignment = Enum.TextXAlignment.Left
		btn.LayoutOrder = layoutOrder
		btn.Parent = Sidebar
		
		local btnCorner = Instance.new("UICorner")
		btnCorner.CornerRadius = UDim.new(0, 6)
		btnCorner.Parent = btn
		
		tabButtons[tabName] = btn
		return page, btn
	end

	-- Instantiate Tab Registry Arrays
	local farmPage, farmBtn         = createPageAndTab("Farm", 1)
	local gamblePage, gambleBtn     = createPageAndTab("Gamble", 2)
	local priorityPage, priorityBtn = createPageAndTab("Priority", 3)
	local miscPage, miscBtn         = createPageAndTab("Misc", 4)

	-- Fast Global Factory Constructor for placeholder features
	local function addTestButton(parentPage, sectionName)
		local testBtn = Instance.new("TextButton")
		testBtn.Name = sectionName .. "TestButton"
		testBtn.Size = UDim2.new(0, 330, 0, 38)
		testBtn.BackgroundColor3 = Color3.fromRGB(32, 32, 32)
		testBtn.Text = "Test (" .. sectionName .. ")"
		testBtn.TextColor3 = Color3.fromRGB(220, 220, 220)
		testBtn.Font = Enum.Font.GothamMedium
		testBtn.TextSize = 13
		testBtn.LayoutOrder = 10
		testBtn.Parent = parentPage
		
		local corner = Instance.new("UICorner")
		corner.CornerRadius = UDim.new(0, 6)
		corner.Parent = testBtn
		
		local stroke = Instance.new("UIStroke")
		stroke.Thickness = 1
		stroke.Color = Color3.fromRGB(48, 48, 48)
		stroke.Parent = testBtn
	end

	-- Populating Content Sections
	local TimelessRaidButton = Instance.new("TextButton")
	TimelessRaidButton.Name = "TimelessRaidToggle"
	TimelessRaidButton.Size = UDim2.new(0, 330, 0, 42)
	TimelessRaidButton.BackgroundColor3 = Color3.fromRGB(28, 28, 28)
	TimelessRaidButton.Text = "Auto Raid: Timeless (OFF)"
	TimelessRaidButton.TextColor3 = Color3.fromRGB(160, 160, 160)
	TimelessRaidButton.Font = Enum.Font.GothamMedium
	TimelessRaidButton.TextSize = 13
	TimelessRaidButton.LayoutOrder = 1
	TimelessRaidButton.Parent = farmPage

	local RaidCorner = Instance.new("UICorner")
	RaidCorner.CornerRadius = UDim.new(0, 6)
	RaidCorner.Parent = TimelessRaidButton

	local RaidStroke = Instance.new("UIStroke")
	RaidStroke.Thickness = 1
	RaidStroke.Color = Color3.fromRGB(45, 45, 45)
	RaidStroke.Parent = TimelessRaidButton

	addTestButton(farmPage, "Farm")
	addTestButton(gamblePage, "Gamble")
	addTestButton(priorityPage, "Priority")

	--- ==========================================
	--- MISC SECTION SLIDER CONFIGURATION
	--- ==========================================
	local SliderContainer = Instance.new("Frame")
	SliderContainer.Name = "SliderContainer"
	SliderContainer.Size = UDim2.new(0, 330, 0, 55)
	SliderContainer.BackgroundTransparency = 1
	SliderContainer.LayoutOrder = 1
	SliderContainer.Parent = miscPage

	local SliderTitle = Instance.new("TextLabel")
	SliderTitle.Name = "SliderTitle"
	SliderTitle.Size = UDim2.new(1, 0, 0, 20)
	SliderTitle.BackgroundTransparency = 1
	SliderTitle.Text = "GUI Scale: 1.00x"
	SliderTitle.TextColor3 = Color3.fromRGB(200, 200, 200)
	SliderTitle.Font = Enum.Font.GothamMedium
	SliderTitle.TextSize = 12
	SliderTitle.TextXAlignment = Enum.TextXAlignment.Left
	SliderTitle.Parent = SliderContainer

	local SliderTrack = Instance.new("Frame")
	SliderTrack.Name = "SliderTrack"
	SliderTrack.Size = UDim2.new(1, 0, 0, 6)
	SliderTrack.Position = UDim2.new(0, 0, 0, 30)
	SliderTrack.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
	SliderTrack.BorderSizePixel = 0
	SliderTrack.Parent = SliderContainer

	local TrackCorner = Instance.new("UICorner")
	TrackCorner.CornerRadius = UDim.new(0, 3)
	TrackCorner.Parent = SliderTrack

	local SliderFill = Instance.new("Frame")
	SliderFill.Name = "SliderFill"
	SliderFill.Size = UDim2.new(0.571, 0, 1, 0)
	SliderFill.BackgroundColor3 = Color3.fromRGB(70, 130, 230)
	SliderFill.BorderSizePixel = 0
	SliderFill.Parent = SliderTrack

	local FillCorner = Instance.new("UICorner")
	FillCorner.CornerRadius = UDim.new(0, 3)
	FillCorner.Parent = SliderFill

	local SliderButton = Instance.new("TextButton")
	SliderButton.Name = "SliderButton"
	SliderButton.Size = UDim2.new(0, 14, 0, 14)
	SliderButton.Position = UDim2.new(0.571, -7, 0.5, -7)
	SliderButton.BackgroundColor3 = Color3.fromRGB(240, 240, 240)
	SliderButton.Text = ""
	SliderButton.Parent = SliderTrack

	local KnobCorner = Instance.new("UICorner")
	KnobCorner.CornerRadius = UDim.new(1, 0)
	KnobCorner.Parent = SliderButton

	local minScale = 0.6
	local maxScale = 1.3
	local isDragging = false

	local function updateSlider(inputObject)
		local trackWidth = SliderTrack.AbsoluteSize.X
		if trackWidth == 0 then trackWidth = 330 end
		
		local mouseX = inputObject.Position.X - SliderTrack.AbsolutePosition.X
		local percentage = math.clamp(mouseX / trackWidth, 0, 1)
		local calculatedScale = minScale + (percentage * (maxScale - minScale))
		
		SliderFill.Size = UDim2.new(percentage, 0, 1, 0)
		SliderButton.Position = UDim2.new(percentage, -7, 0.5, -7)
		SliderTitle.Text = string.format("GUI Scale: %.2fx", calculatedScale)
		
		PanelScale.Scale = calculatedScale
	end

	SliderButton.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			isDragging = true
		end
	end)

	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			isDragging = false
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if isDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			updateSlider(input)
		end
	end)

	--- ==========================================
	--- NAVIGATION & ROUTING HANDLERS
	--- ==========================================
	local function switchTab(tabName)
		for name, button in pairs(tabButtons) do
			button.BackgroundTransparency = 1
			button.TextColor3 = Color3.fromRGB(140, 140, 140)
			pages[name].Visible = false
		end
		
		local targetBtn = tabButtons[tabName]
		if targetBtn then
			targetBtn.BackgroundTransparency = 0
			targetBtn.BackgroundColor3 = Color3.fromRGB(32, 32, 32)
			targetBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
			pages[tabName].Visible = true
		end
	end

	for name, button in pairs(tabButtons) do
		button.MouseButton1Click:Connect(function()
			switchTab(name)
		end)
	end

	switchTab("Farm")

	-- Clean Minimalist Toggle Mechanics
	local isTimelessActive = false
	TimelessRaidButton.MouseButton1Click:Connect(function()
		isTimelessActive = not isTimelessActive
		if isTimelessActive then
			TimelessRaidButton.BackgroundColor3 = Color3.fromRGB(24, 32, 45)
			TimelessRaidButton.TextColor3 = Color3.fromRGB(100, 180, 255)
			RaidStroke.Color = Color3.fromRGB(50, 90, 160)
			TimelessRaidButton.Text = "Auto Raid: Timeless (ON)"
		else
			TimelessRaidButton.BackgroundColor3 = Color3.fromRGB(28, 28, 28)
			TimelessRaidButton.TextColor3 = Color3.fromRGB(160, 160, 160)
			RaidStroke.Color = Color3.fromRGB(45, 45, 45)
			TimelessRaidButton.Text = "Auto Raid: Timeless (OFF)"
		end
	end)

	CloseButton.MouseButton1Click:Connect(function()
		ScreenGui:Destroy()
	end)

	--- ==========================================
	--- GLOBAL HUD INTERACTION SYSTEM
	--- ==========================================
	local ToggleButton = Instance.new("TextButton")
	ToggleButton.Name = "HUDDisplayToggle"
	ToggleButton.Size = UDim2.new(0, 90, 0, 32)
	ToggleButton.Position = UDim2.new(0, 15, 0, 15)
	ToggleButton.BackgroundColor3 = Color3.fromRGB(18, 18, 18)
	ToggleButton.Text = "Toggle UI"
	ToggleButton.TextColor3 = Color3.fromRGB(200, 200, 200)
	ToggleButton.Font = Enum.Font.GothamMedium
	ToggleButton.TextSize = 12
	ToggleButton.ZIndex = 10
	ToggleButton.Parent = ScreenGui

	local UIStrokeToggle = Instance.new("UIStroke")
	UIStrokeToggle.Thickness = 1
	UIStrokeToggle.Color = Color3.fromRGB(45, 45, 45)
	UIStrokeToggle.Parent = ToggleButton

	local ToggleCorner = Instance.new("UICorner")
	ToggleCorner.CornerRadius = UDim.new(0, 6)
	ToggleCorner.Parent = ToggleButton

	ToggleButton.MouseButton1Click:Connect(function()
		MainFrame.Visible = not MainFrame.Visible
	end)

end)
