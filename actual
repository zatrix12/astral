-- LocalScript - Place inside StarterGui for the fastest execution path
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local localPlayer = Players.LocalPlayer

-- 1. FAST-BOOTSTRAP ENGINE: Immediate acquisition without thread stalls
local playerGui = localPlayer:FindFirstChildOfClass("PlayerGui")
if not playerGui then
	playerGui = localPlayer:WaitForChild("PlayerGui", 5)
end

-- Fallback safety check if player spawned into a heavily lagged server
if not playerGui then
	task.wait()
	playerGui = localPlayer:FindFirstChildOfClass("PlayerGui") or localPlayer:WaitForChild("PlayerGui")
end

-- Wrap entire UI instantiation inside an isolated task thread so it compiles instantly
task.spawn(function()
	
	-- Core ScreenGui Container
	local ScreenGui = Instance.new("ScreenGui")
	ScreenGui.Name = "ZatrixPremiumHub"
	ScreenGui.ResetOnSpawn = false
	ScreenGui.Parent = playerGui

	-- Main Structural Window Frame
	local MainFrame = Instance.new("Frame")
	MainFrame.Name = "MainWindow"
	MainFrame.Size = UDim2.new(0, 520, 0, 340)
	MainFrame.Position = UDim2.new(0.5, -260, 0.5, -170)
	MainFrame.BackgroundColor3 = Color3.fromRGB(18, 18, 18)
	MainFrame.BorderSizePixel = 0
	MainFrame.Active = true
	MainFrame.Draggable = true
	MainFrame.Parent = ScreenGui

	-- Dynamic Scaling Component (Parented immediately to avoid freeze anomalies)
	local PanelScale = Instance.new("UIScale")
	PanelScale.Name = "PanelScale"
