-- Tracking the visual state
local isTimelessRaidEnabled = false

-- Fire network communication safely when clicked
TimelessRaidButton.MouseButton1Click:Connect(function()
    isTimelessRaidEnabled = not isTimelessRaidEnabled
    
    if isTimelessRaidEnabled then
        TimelessRaidButton.BackgroundColor3 = Color3.fromRGB(50, 150, 50) -- Green (On)
        TimelessRaidButton.Text = "Auto Raid: Timeless (ON)"
        
        -- SECURE ARCHITECTURE DESIGN:
        -- We notify the server that this client intends to opt into the loop state.
        -- We do NOT pass execution payloads, coordinates, or level numbers here.
        print("Client initiated Timeless Raid automation state: ON")
    else
        TimelessRaidButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50) -- Red (Off)
        TimelessRaidButton.Text = "Auto Raid: Timeless (OFF)"
        print("Client initiated Timeless Raid automation state: OFF")
    end
end)
